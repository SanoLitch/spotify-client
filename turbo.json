{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^pipeline:build", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "test": {
      "dependsOn": ["^pipeline:build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.ts", "vitest.setup.ts"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:cov": {
      "dependsOn": ["^pipeline:build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.ts", "vitest.setup.ts"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:arch": {
      "dependsOn": ["^pipeline:build"],
      "inputs": ["$TURBO_DEFAULT$", ".dependency-cruiser.js", ".dependency-cruiser.cjs"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["^pipeline:build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.e2e.config.ts"],
      "cache": true
    },
    "test:back": {
      "dependsOn": ["^pipeline:build"],
      "with": ["@spotify/backend#test"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.ts"],
      "cache": true
    },
    "test:front": {
      "dependsOn": ["^pipeline:build"],
      "with": ["@spotify/frontend#test"],
      "inputs": ["$TURBO_DEFAULT$", "vite.config.ts", "vitest.setup.ts"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", ".eslintrc*", "eslint.config.*"],
      "cache": true
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$", ".eslintrc*", "eslint.config.*"],
      "cache": false
    },
    "start:dev": {
      "dependsOn": ["^pipeline:build"],
      "cache": false,
      "persistent": true
    },
    "start:back": {
      "dependsOn": ["^pipeline:build"],
      "with": ["@spotify/backend#start:dev"],
      "cache": false,
      "persistent": true
    },
    "pipeline:build": {
      "cache": true,
      "persistent": false,
      "outputs": ["dist/**"]
    }
  }
}

